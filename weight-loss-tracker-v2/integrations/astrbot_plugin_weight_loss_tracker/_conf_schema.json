{
  "backend_base_url": {
    "description": "Weight Loss Tracker 后端地址",
    "type": "string",
    "default": "http://weight-loss-tracker:8080"
  },
  "allow_private": {
    "description": "允许私聊使用",
    "type": "bool",
    "default": true
  },
  "allow_group": {
    "description": "允许群聊使用",
    "type": "bool",
    "default": true
  },
  "pending_ttl_seconds": {
    "description": "估算记录等待确认的有效秒数",
    "type": "int",
    "default": 600,
    "slider": {
      "min": 60,
      "max": 3600,
      "step": 30
    }
  },
  "request_timeout_seconds": {
    "description": "后端 HTTP 请求超时秒数",
    "type": "int",
    "default": 5,
    "slider": {
      "min": 1,
      "max": 30,
      "step": 1
    }
  }
}
